# ── Wo bleibt mein Zug? — Umgebungsvariablen ─────────────────────────────
# Kopieren nach .env.local (Next.js lädt .env.local automatisch):
#   PowerShell:  copy .env.example .env.local
#   Git Bash:    cp .env.example .env.local

# ── Pflicht ──────────────────────────────────────────────────────────────
# Mistral API Key — https://console.mistral.ai/api-keys
# Europäisches Modell (Mistral Small), EU-Datenhaltung, günstig.
MISTRAL_API_KEY=

# Modell (optional, Default: mistral-small-latest)
# Alternativen: ministral-8b-latest (günstiger), mistral-medium-latest (besser)
MISTRAL_MODEL=mistral-small-latest

# ── Optional: Rate-Limiting für öffentliche Demo ─────────────────────────
# Vercel Marketplace → Upstash Redis (Free Tier). Ohne diese Werte läuft
# ein In-Memory-Fallback (reicht für lokale Entwicklung, nicht für Prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tages-Cap an Nachrichten für die öffentliche Demo (Kostenschutz)
DAILY_MESSAGE_CAP=1500

# Nachrichten pro IP je 5-Minuten-Fenster
RATE_LIMIT_PER_IP=10

# ── Optional: offizielle DB-APIs (Bahnhofs-Ausstattung + Aufzugsstatus) ──
# Kostenlos registrieren: https://developers.deutschebahn.com/db-api-marketplace
# Anwendung anlegen → APIs "StaDa/Station Data" und "FaSta" abonnieren → Keys kopieren.
# Ohne diese Werte funktioniert die App normal; nur die Bahnhofs-Ausstattungs-
# und Aufzug-Tools melden dann „noch nicht konfiguriert".
DB_CLIENT_ID=
DB_API_KEY=
